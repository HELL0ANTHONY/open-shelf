<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Reglas que complementan google-java-format:
  - El formatter maneja espaciado, indentación y longitud de línea.
  - Checkstyle maneja nombres, diseño OOP, Javadoc y complejidad.
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="charset" value="UTF-8"/>

  <!-- Habilita @SuppressWarnings("checkstyle:RuleName") en el código -->
  <module name="SuppressWarningsFilter"/>

  <!-- Archivos no deben usar tabs (google-java-format usa espacios) -->
  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
  </module>

  <module name="TreeWalker">

    <!-- Requerido por SuppressWarningsFilter -->
    <module name="SuppressWarningsHolder"/>

    <!-- ── Convenciones de nombres ── -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>
    <module name="TypeName"/>
    <module name="MethodName"/>
    <module name="ConstantName"/>
    <module name="MemberName"/>
    <module name="LocalVariableName"/>
    <module name="ParameterName"/>
    <module name="StaticVariableName"/>
    <module name="LocalFinalVariableName"/>

    <!-- ── Imports ── -->
    <!-- Fuerza imports explícitos: aprendes exactamente qué usás -->
    <module name="AvoidStarImport"/>
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>
    <module name="IllegalImport"/>

    <!-- ── Javadoc para API pública ── -->
    <!-- Documentar la interfaz pública es parte del diseño OOP -->
    <module name="MissingJavadocType">
      <property name="scope" value="public"/>
    </module>
    <module name="MissingJavadocMethod">
      <property name="scope" value="public"/>
      <!-- Getters/setters simples quedan exentos -->
      <property name="allowMissingPropertyJavadoc" value="true"/>
    </module>
    <module name="JavadocMethod">
      <property name="accessModifiers" value="public"/>
    </module>

    <!-- ── Diseño OOP ── -->
    <!-- Encapsulación: campos no pueden ser public/package-private -->
    <module name="VisibilityModifier">
      <property name="protectedAllowed" value="true"/>
    </module>
    <!-- Evita que parámetros/variables locales oculten campos del objeto -->
    <module name="HiddenField">
      <property name="ignoreSetter" value="true"/>
      <property name="ignoreConstructorParameter" value="true"/>
    </module>
    <!-- Siempre usar {} en if/for/while — previene bugs sutiles -->
    <module name="NeedBraces"/>
    <!-- equals y hashCode deben implementarse juntos o ninguno -->
    <module name="EqualsHashCode"/>

    <!-- ── Calidad de código ── -->
    <!-- Usar constantes nombradas en vez de números literales -->
    <module name="MagicNumber">
      <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
      <property name="ignoreHashCodeMethod" value="true"/>
      <property name="ignoreAnnotation" value="true"/>
    </module>
    <!-- Comparar Strings con == es un bug clásico en Java -->
    <module name="StringLiteralEquality"/>
    <!-- Bloques catch/finally vacíos ocultan errores -->
    <module name="EmptyBlock"/>
    <!-- Simplifica expresiones booleanas redundantes -->
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>

    <!-- ── Complejidad / tamaño ── -->
    <!-- Métodos largos violan SRP; 30 líneas es un límite generoso pero firme -->
    <module name="MethodLength">
      <property name="max" value="30"/>
    </module>
    <!-- Demasiados parámetros = mal diseño de interfaz -->
    <module name="ParameterNumber">
      <property name="max" value="5"/>
    </module>
    <!-- Complejidad ciclomática alta = código difícil de testear -->
    <module name="CyclomaticComplexity">
      <property name="max" value="10"/>
    </module>

  </module>
</module>
